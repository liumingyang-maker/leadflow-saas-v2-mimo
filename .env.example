# .env.example - template for environment setup
APP_ENV=development
SECRET_KEY=<generate-32+-char-secret>
TENANT_SECRET_KEY=<generate-32+-char-secret>
DATABASE_URL=sqlite:///leadflow-v2-dev.db
REDIS_URL=redis://localhost:6379/0
DEEPSEEK_API_KEY=<your-deepseek-api-key>

# Staging/production baseline
# APP_ENV=staging
# POSTGRES_PASSWORD=<generate-strong-postgres-password>
# DATABASE_URL=postgresql://leadflow:<postgres-password>@db:5432/leadflow
# REDIS_URL=redis://redis:6379/0
# SESSION_COOKIE_SECURE=true
# WTF_CSRF_ENABLED=true
# PROXY_FIX_HOPS=1
# SERVER_NAME=staging.example.com
# ALLOWED_HOSTS=staging.example.com
# INBOUND_TOKEN_KEY=<required-32+-char-secret-for-staging-production>
# OUTREACH_SIGNING_KEY=<required-32+-char-secret-for-staging-production>

# SMTP Configuration (for real email sending)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=<your-smtp-password>
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true

# Google Search API (for real lead collection)
# GOOGLE_SEARCH_API_KEY=<your-google-api-key>
# GOOGLE_SEARCH_CX=<your-custom-search-engine-id>

# Google Maps API (for real business collection)
# GOOGLE_MAPS_API_KEY=<your-google-maps-api-key>
